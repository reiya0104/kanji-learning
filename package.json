    "test:e2e:ios": "detox test -c ios.sim.debug",
    "build:e2e": "detox build -c android.emu.debug"
  },
  "dependencies": {
    "@expo-google-fonts/noto-sans-jp": "^0.4.3",
    "@react-navigation/native": "^7.2.0",
