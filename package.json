{
  "name": "kanji-learning",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'App.tsx' 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}'",
